# ─────────────────────────────────────────────────────────────
# AgentForge backend configuration
# Copy to `.env` and adjust. Everything has a sensible default —
# with NO changes the app runs fully offline (mock LLM + local
# embeddings + SQLite), so you can demo it without any API keys.
# ─────────────────────────────────────────────────────────────

# --- Database ---------------------------------------------------
# SQLite (default, zero setup):
DATABASE_URL=sqlite:///./agentforge.db
# Postgres + pgvector (production):
# DATABASE_URL=postgresql+psycopg://agentforge:agentforge@localhost:5432/agentforge
# Plain postgres:// / postgresql:// URLs (Railway/Render/Supabase) are
# auto-normalized to the psycopg driver, so you can paste them as-is.

# --- LLM provider ----------------------------------------------
# auto = OpenAI if OPENAI_API_KEY is set, else Anthropic if
#        ANTHROPIC_API_KEY is set, else the deterministic mock
#        provider (great for offline, zero-cost demos).
LLM_PROVIDER=auto
# OpenAI — the default LLM provider.
OPENAI_API_KEY=
# Anthropic — alternative LLM provider.
ANTHROPIC_API_KEY=
# Default model for new agents (OpenAI by default; e.g. gpt-4o, gpt-4.1-mini).
DEFAULT_MODEL=gpt-4o-mini
MAX_TOKENS=4096

# --- Embeddings -------------------------------------------------
# Local hashing embedder (offline, free) by default. Set
# EMBEDDINGS_PROVIDER=openai to use text-embedding-3-small via the
# OPENAI_API_KEY above (re-ingest documents after switching).
EMBEDDINGS_PROVIDER=auto
EMBEDDING_DIM=384

# --- RAG --------------------------------------------------------
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=4

# --- App --------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
SEED_ON_STARTUP=true
