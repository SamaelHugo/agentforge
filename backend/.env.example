# ─────────────────────────────────────────────────────────────
# AgentForge backend configuration
# Copy to `.env` and adjust. Everything has a sensible default —
# with NO changes the app runs fully offline (mock LLM + local
# embeddings + SQLite), so you can demo it without any API keys.
# ─────────────────────────────────────────────────────────────

# --- Database ---------------------------------------------------
# SQLite (default, zero setup):
DATABASE_URL=sqlite:///./agentforge.db
# Postgres + pgvector (production):
# DATABASE_URL=postgresql+psycopg://agentforge:agentforge@localhost:5432/agentforge
# Plain postgres:// / postgresql:// URLs (Railway/Render/Supabase) are
# auto-normalized to the psycopg driver, so you can paste them as-is.

# --- LLM provider ----------------------------------------------
# auto = use Anthropic if ANTHROPIC_API_KEY is set, otherwise the
#        deterministic mock provider (great for offline demos).
LLM_PROVIDER=auto
ANTHROPIC_API_KEY=
# Default model for new agents. Per the design doc you can switch to
# claude-haiku-4-5 / claude-sonnet-4-6 to cut cost during development.
DEFAULT_MODEL=claude-opus-4-8
MAX_TOKENS=4096

# --- Embeddings -------------------------------------------------
# auto = OpenAI if OPENAI_API_KEY is set, otherwise the local
#        deterministic hashing embedder (offline, no deps).
EMBEDDINGS_PROVIDER=auto
OPENAI_API_KEY=
EMBEDDING_DIM=384

# --- RAG --------------------------------------------------------
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=4

# --- App --------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
SEED_ON_STARTUP=true
